#!/bin/sh

#################################################################################
#
# Lynis Custom Plugin - Ransomware Indicators
# Plugin ID:    CUS-RANSOM
# Description:  Checks for common ransomware indicators and hardening fields:
#               - ransomware_known_extensions_found
#               - ransomware_backup_present
#               - ransomware_immutable_backups
#               - ransomware_suspicious_cron
#               - ransomware_shadow_copies_present
#               - ransomware_mass_encrypt_tool_present
#
# Author:       Custom
# License:      GPL
# Version:      1.0.0
#
# Usage:        Enable plugin in profile:
#               plugin=plugin_ransomware_indicators_phase1
#
# NOTE: This plugin identifies INDICATORS only - not definitive detection.
#
#################################################################################

PLUGIN_NAME="Ransomware Indicators"
PLUGIN_AUTHOR="Custom"
PLUGIN_VERSION="1.0.0"
PLUGIN_ID="CUS-RANSOM"
PLUGIN_REQUIRED_OS="Linux"

# Common ransomware file extensions
RANSOM_EXTENSIONS=".locked .encrypted .enc .crypto .crypt .pays .wnry .wncry .cerber .locky .zepto .odin .thor .aesir .xtbl .vault .petya .WNCRY .WCRY .onion .decrypt .crypted .CRYPTED"

if [ "${PLUGIN_PHASE}" = "1" ]; then

    InsertSection "Custom Plugin: Ransomware Indicators"

    # ------------------------------------------------------------------
    # CUS-RANSOM-001: Known ransomware file extensions in common dirs
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-001" --weight H --network NO \
        --category malware --description "Check for known ransomware file extensions"

    if [ ${SKIPTEST} -eq 0 ]; then
        RANSOM_FILES_FOUND=0
        FOUND_EXTENSIONS=""

        SEARCH_DIRS="/home /var/www /opt /srv /data /tmp"

        for EXT in ${RANSOM_EXTENSIONS}; do
            # Search with a depth limit to avoid performance issues
            FOUND=$(find ${SEARCH_DIRS} -maxdepth 5 -name "*${EXT}" -type f 2>/dev/null | head -5)
            if [ -n "${FOUND}" ]; then
                RANSOM_FILES_FOUND=$(( RANSOM_FILES_FOUND + 1 ))
                FOUND_EXTENSIONS="${FOUND_EXTENSIONS} ${EXT}"
                LogText "Found ransomware extension ${EXT}: $(echo "${FOUND}" | head -1)"
            fi
        done

        LogText "Result: ransomware_known_extensions_found = ${RANSOM_FILES_FOUND}"
        Report "ransomware_known_extensions_found=${RANSOM_FILES_FOUND}"
        [ -n "${FOUND_EXTENSIONS}" ] && Report "ransomware_found_extensions=${FOUND_EXTENSIONS}"

        if [ ${RANSOM_FILES_FOUND} -eq 0 ]; then
            Display --indent 4 --text "- Ransomware file extensions" --result "NONE FOUND" --color GREEN
        else
            Display --indent 4 --text "- Ransomware file extensions" --result "${RANSOM_FILES_FOUND} TYPES FOUND" --color RED
            ReportWarning "${TEST_NO}" "Potential ransomware file extensions detected (${FOUND_EXTENSIONS}) - investigate immediately"
        fi
    fi

    # ------------------------------------------------------------------
    # CUS-RANSOM-002: Backup presence check
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-002" --weight H --network NO \
        --category malware --description "Check for backup presence"

    if [ ${SKIPTEST} -eq 0 ]; then
        BACKUP_FOUND=0
        BACKUP_TOOLS=""

        # Check for common backup tools/services
        for TOOL in rsync bacula amanda borgbackup duplicati restic timeshift; do
            if which "${TOOL}" >/dev/null 2>&1 || IsRunning "${TOOL}"; then
                BACKUP_FOUND=$(( BACKUP_FOUND + 1 ))
                BACKUP_TOOLS="${BACKUP_TOOLS} ${TOOL}"
            fi
        done

        # Check common backup directories
        BACKUP_DIRS_FOUND=0
        for DIR in /backup /var/backup /srv/backup /mnt/backup /media/backup; do
            [ -d "${DIR}" ] && BACKUP_DIRS_FOUND=$(( BACKUP_DIRS_FOUND + 1 ))
        done

        LogText "Result: backup tools found = ${BACKUP_FOUND}, backup dirs = ${BACKUP_DIRS_FOUND}"
        Report "ransomware_backup_tool_present=${BACKUP_FOUND}"
        Report "ransomware_backup_dirs_found=${BACKUP_DIRS_FOUND}"
        [ -n "${BACKUP_TOOLS}" ] && Report "ransomware_backup_tools=${BACKUP_TOOLS}"

        if [ ${BACKUP_FOUND} -gt 0 ] || [ ${BACKUP_DIRS_FOUND} -gt 0 ]; then
            Display --indent 4 --text "- Backup presence" --result "DETECTED" --color GREEN
        else
            Display --indent 4 --text "- Backup presence" --result "NONE DETECTED" --color RED
            ReportWarning "${TEST_NO}" "No backup tools or directories detected - system has no ransomware recovery option"
        fi
    fi

    # ------------------------------------------------------------------
    # CUS-RANSOM-003: Immutable backup check (chattr +i)
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-003" --weight M --network NO \
        --category malware --description "Check for immutable backup files"

    if [ ${SKIPTEST} -eq 0 ]; then
        IMMUTABLE_COUNT=0
        CHATTR=$(which chattr 2>/dev/null)
        LSATTR=$(which lsattr 2>/dev/null)

        if [ -n "${LSATTR}" ]; then
            for DIR in /backup /var/backup /srv/backup; do
                if [ -d "${DIR}" ]; then
                    COUNT=$(${LSATTR} -R "${DIR}" 2>/dev/null | grep "^----i" | wc -l | tr -d ' ')
                    IMMUTABLE_COUNT=$(( IMMUTABLE_COUNT + COUNT ))
                fi
            done
        fi

        LogText "Result: ransomware_immutable_backups = ${IMMUTABLE_COUNT}"
        Report "ransomware_immutable_backups=${IMMUTABLE_COUNT}"

        if [ ${IMMUTABLE_COUNT} -gt 0 ]; then
            Display --indent 4 --text "- Immutable backup files" --result "${IMMUTABLE_COUNT} FOUND" --color GREEN
        else
            Display --indent 4 --text "- Immutable backup files" --result "NONE" --color YELLOW
            ReportSuggestion "${TEST_NO}" "Use 'chattr +i' on backup files to make them immutable against ransomware"
        fi
    fi

    # ------------------------------------------------------------------
    # CUS-RANSOM-004: Suspicious cron jobs (high-frequency or unusual)
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-004" --weight M --network NO \
        --category malware --description "Check for suspicious cron entries"

    if [ ${SKIPTEST} -eq 0 ]; then
        SUSPICIOUS_CRON=0

        # Patterns: base64 encoded commands, curl/wget to external, /tmp execution
        SUSPICIOUS_PATTERNS="base64.*decode\|curl.*http\|wget.*http\|/tmp/.*sh\|python.*-c\|bash.*-i"

        for CRON_DIR in /etc/cron.d /etc/cron.daily /etc/cron.hourly /var/spool/cron/crontabs; do
            if [ -d "${CRON_DIR}" ]; then
                COUNT=$(grep -rl "${SUSPICIOUS_PATTERNS}" "${CRON_DIR}/" 2>/dev/null | wc -l | tr -d ' ')
                SUSPICIOUS_CRON=$(( SUSPICIOUS_CRON + COUNT ))
            fi
        done

        # Also check /etc/crontab
        if [ -f "/etc/crontab" ]; then
            COUNT=$(grep -c "${SUSPICIOUS_PATTERNS}" /etc/crontab 2>/dev/null || echo 0)
            SUSPICIOUS_CRON=$(( SUSPICIOUS_CRON + COUNT ))
        fi

        LogText "Result: ransomware_suspicious_cron = ${SUSPICIOUS_CRON}"
        Report "ransomware_suspicious_cron=${SUSPICIOUS_CRON}"

        if [ ${SUSPICIOUS_CRON} -eq 0 ]; then
            Display --indent 4 --text "- Suspicious cron patterns" --result "NONE" --color GREEN
        else
            Display --indent 4 --text "- Suspicious cron patterns" --result "${SUSPICIOUS_CRON} FOUND" --color RED
            ReportWarning "${TEST_NO}" "Suspicious cron patterns found (${SUSPICIOUS_CRON}) - review cron jobs for malicious activity"
        fi
    fi

    # ------------------------------------------------------------------
    # CUS-RANSOM-005: Shadow copies / snapshots present
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-005" --weight M --network NO \
        --category malware --description "Check for filesystem snapshots"

    if [ ${SKIPTEST} -eq 0 ]; then
        SNAPSHOTS_FOUND=0
        SNAPSHOT_TYPES=""

        # LVM snapshots
        if which lvs >/dev/null 2>&1; then
            LVM_SNAPS=$(lvs --noheadings -o lv_attr 2>/dev/null | grep "^  s" | wc -l | tr -d ' ')
            [ "${LVM_SNAPS}" -gt 0 ] 2>/dev/null && SNAPSHOTS_FOUND=$(( SNAPSHOTS_FOUND + LVM_SNAPS )) && SNAPSHOT_TYPES="${SNAPSHOT_TYPES} LVM(${LVM_SNAPS})"
        fi

        # Btrfs snapshots
        if which btrfs >/dev/null 2>&1; then
            BTRFS_SNAPS=$(btrfs subvolume list / 2>/dev/null | grep -ci "snapshot" || echo 0)
            [ "${BTRFS_SNAPS}" -gt 0 ] 2>/dev/null && SNAPSHOTS_FOUND=$(( SNAPSHOTS_FOUND + BTRFS_SNAPS )) && SNAPSHOT_TYPES="${SNAPSHOT_TYPES} BTRFS(${BTRFS_SNAPS})"
        fi

        # ZFS snapshots
        if which zfs >/dev/null 2>&1; then
            ZFS_SNAPS=$(zfs list -t snapshot 2>/dev/null | grep -c "@" || echo 0)
            [ "${ZFS_SNAPS}" -gt 0 ] 2>/dev/null && SNAPSHOTS_FOUND=$(( SNAPSHOTS_FOUND + ZFS_SNAPS )) && SNAPSHOT_TYPES="${SNAPSHOT_TYPES} ZFS(${ZFS_SNAPS})"
        fi

        LogText "Result: ransomware_shadow_copies_present = ${SNAPSHOTS_FOUND}"
        Report "ransomware_shadow_copies_present=${SNAPSHOTS_FOUND}"
        [ -n "${SNAPSHOT_TYPES}" ] && Report "ransomware_snapshot_types=${SNAPSHOT_TYPES}"

        if [ ${SNAPSHOTS_FOUND} -gt 0 ]; then
            Display --indent 4 --text "- Filesystem snapshots" --result "${SNAPSHOTS_FOUND} FOUND${SNAPSHOT_TYPES}" --color GREEN
        else
            Display --indent 4 --text "- Filesystem snapshots" --result "NONE" --color YELLOW
            ReportSuggestion "${TEST_NO}" "Configure filesystem snapshots (LVM/BTRFS/ZFS) to enable ransomware recovery"
        fi
    fi

    # ------------------------------------------------------------------
    # CUS-RANSOM-006: Known encryption tools present (dual-use)
    # ------------------------------------------------------------------
    Register --test-no "CUS-RANSOM-006" --weight L --network NO \
        --category malware --description "Check for mass encryption tools"

    if [ ${SKIPTEST} -eq 0 ]; then
        ENCRYPT_TOOLS=""
        ENCRYPT_COUNT=0

        for TOOL in openssl gpg ccrypt mcrypt; do
            if which "${TOOL}" >/dev/null 2>&1; then
                ENCRYPT_COUNT=$(( ENCRYPT_COUNT + 1 ))
                ENCRYPT_TOOLS="${ENCRYPT_TOOLS} ${TOOL}"
            fi
        done

        LogText "Result: ransomware_mass_encrypt_tool_present = ${ENCRYPT_COUNT}"
        Report "ransomware_mass_encrypt_tool_present=${ENCRYPT_COUNT}"
        [ -n "${ENCRYPT_TOOLS}" ] && Report "ransomware_encrypt_tools=${ENCRYPT_TOOLS}"

        Display --indent 4 --text "- Encryption tools present" --result "${ENCRYPT_COUNT} (${ENCRYPT_TOOLS})" --color WHITE
        LogText "Note: Encryption tools are dual-use - presence alone is not an indicator of compromise"
    fi

fi # end phase 1
